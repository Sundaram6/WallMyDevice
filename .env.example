# WallMyDevice — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.

# ─── Authentication (optional) ────────────────────────────────────────────────
# All generator, archive, and export features work without authentication.
# Set these only if you want real user accounts.

# Provider name shown on the Sign In button
# NEXT_PUBLIC_AUTH_PROVIDER=google

# Auth.js secret — generate with: openssl rand -base64 32
# AUTH_SECRET=

# Google OAuth — create credentials at https://console.cloud.google.com/
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth — create app at https://github.com/settings/developers
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Canonical URL of your deployment (used for OAuth callbacks)
# NEXTAUTH_URL=https://your-domain.vercel.app

# ─── Analytics (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=
